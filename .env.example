POSTGRES_DB=retail_assistant
POSTGRES_USER=
POSTGRES_PASSWORD=
JWT_SECRET=
JWT_EXPIRATION_HOURS=72
OPENAI_API_KEY=
# Tesco (Apify) + Sainsbury's (Playwright) connectors removed in v1.1 per sprint
# B12.1 — grocery moved to NourishOS. APIFY_API_KEY is no longer required;
# if set, it is ignored.
PYTHON_AI_SERVICE_URL=http://ai-service:8001
PLAYWRIGHT_HEADLESS=true
NEXT_PUBLIC_API_URL=http://localhost:8080

# Frontend demo / dev flags
# Set NEXT_PUBLIC_USE_MOCKS=true to drive the UI from mock fixtures
# (no backend required — useful for demo recordings).
NEXT_PUBLIC_USE_MOCKS=false
# Set NEXT_PUBLIC_DEV_TOOLS=true to surface the admin connector status view.
NEXT_PUBLIC_DEV_TOOLS=false
